# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/twgt_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379
REDIS_TTL=300

# Neo4j
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Qdrant Vector DB
VECTOR_DB_URL=http://localhost:6333
VECTOR_DB_API_KEY=

# OpenAI
OPENAI_API_KEY=sk_...
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# DeepSeek
DEEPSEEK_API_KEY=sk_...
DEEPSEEK_MODEL=deepseek-chat

# JWT
JWT_SECRET=your-super-secret-key-min-32-characters-long
JWT_EXPIRY=1h
REFRESH_SECRET=your-refresh-secret-key-min-32-characters
REFRESH_EXPIRY=7d

# Features
ENABLE_TELEMETRY=true
ENABLE_MONITORING=true
LOG_LEVEL=info
LOG_FORMAT=pretty

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=*
CORS_CREDENTIALS=true
